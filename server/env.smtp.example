# Configuration SMTP pour l'envoi d'emails
# IMPORTANT: Pour Gmail, vous DEVEZ utiliser un "Mot de passe d'application"
# Guide complet: server/docs/SMTP_CONFIG.md

# Option 1: Gmail (Recommandé pour développement)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application-gmail
SMTP_FROM=votre-email@gmail.com
SMTP_REJECT_UNAUTHORIZED=true

# Option 2: Gmail avec SSL (port 465)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=votre-email@gmail.com
# SMTP_PASS=votre-mot-de-passe-application-gmail
# SMTP_FROM=votre-email@gmail.com

# Option 3: SendGrid (via SMTP - peut être bloqué sur Render)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=votre-api-key-sendgrid
# SMTP_FROM=noreply@tokana.mg

# Option 3b: SendGrid (via API REST - RECOMMANDÉ pour Render.com)
# SENDGRID_API_KEY=votre-api-key-sendgrid
# SENDGRID_FROM=noreply@tokana.mg
# SENDGRID_FROM_NAME=Tokana

# Option 4: Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@votre-domaine.mailgun.org
# SMTP_PASS=votre-mot-de-passe-mailgun
# SMTP_FROM=noreply@tokana.mg

# Option 5: SMTP personnalisé
# SMTP_HOST=smtp.votre-domaine.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@votre-domaine.com
# SMTP_PASS=votre-mot-de-passe
# SMTP_FROM=noreply@votre-domaine.com
# SMTP_REJECT_UNAUTHORIZED=false

