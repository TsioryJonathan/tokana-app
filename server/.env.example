# Tokana Server - .env.example
# Duplicate this file as `.env` and fill in the values.

# ===== Core =====
NODE_ENV=development
PORT=5000

# ===== Database (Sequelize) =====
# Used by config/config.json -> development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tokana_dev
DB_USER=postgres
DB_PASS=postgres

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# ===== Security / JWT =====
# Generate strong secrets (openssl rand -base64 48)
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=60m

# Refresh tokens (optional if enabled)
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
ACCESS_TOKEN_TTL=60m
REFRESH_TOKEN_TTL=30d

# ===== Business Timezone / Slots =====
BUSINESS_TZ=Indian/Antananarivo
SLOTS_DEV_ALWAYS_ON=true

# ===== OTP Proof of Delivery =====
# Secret to hash OTP codes (openssl rand -base64 32)
OTP_SECRET=replace_with_random_secret
OTP_TTL_MINUTES=5

# ===== SMS Provider =====
# befiana | dev
SMS_PROVIDER=dev

# If you use Befiana, fill in:
SMS_BEFIANA_API_URL=https://api.befiana.cloud/sms/send
SMS_BEFIANA_API_KEY=replace_with_befiana_api_key
SMS_SENDER_ID=TOKANA

# ===== Email (fallback OTP, reset, etc.) =====
# If not provided -> DEV mode (logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Tokana <no-reply@tokana.mg>"

# ===== Rate limit (optional) =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===== Business contact (manual handling) =====
# Phone number shown to users when weight > 5kg requires manual handling (Optional)
CONTACT_PHONE=+26134XXXXXXX
