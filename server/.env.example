# Tokana Server - .env.example
# Duplicate this file as `.env` and fill in the values.

# ===== Core =====
NODE_ENV=development
PORT=5000

# ===== Database (Sequelize) =====
# Runtime and sequelize-cli both read POSTGRES_URI (see config/config.json and config/sequelize.js)
# Example: postgres://USER:PASS@HOST:PORT/DBNAME
POSTGRES_URI=postgres://postgres:postgres@localhost:5432/tokana_dev

# ===== CORS =====
# Comma-separated list of allowed origins (leave empty in DEV to allow all)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ===== Security / JWT =====
# Generate strong secrets (openssl rand -base64 48)
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=60m

# Refresh tokens (optional if enabled)
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
ACCESS_TOKEN_TTL=60m
REFRESH_TOKEN_TTL=30d

# ===== Business Timezone / Slots =====
BUSINESS_TZ=Indian/Antananarivo
SLOTS_DEV_ALWAYS_ON=true

# --- Admin bootstrap (for seeder 20250817010500-seed-admin.js) ---
# WARNING: Do not commit real passwords. Copy to .env and fill locally.
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+261201234567
ADMIN_NAME=Super Admin
ADMIN_PASSWORD=changeMe123

# ===== OTP Proof of Delivery =====
# Secret to hash OTP codes (openssl rand -base64 32)
OTP_SECRET=replace_with_random_secret
OTP_TTL_MINUTES=5
# OTP resend smoothing
OTP_WINDOW_MINUTES=10
OTP_COOLDOWN_STEPS=0,60,120,300

# OTP verify limits
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_LOCK_MINUTES=5

# ===== SMS Provider =====
# befiana | dev
SMS_PROVIDER=dev

# If you use Befiana, fill in:
SMS_BEFIANA_API_URL=https://api.befiana.cloud/sms/send
SMS_BEFIANA_API_KEY=replace_with_befiana_api_key
SMS_SENDER_ID=TOKANA

# ===== Email (fallback OTP, reset, etc.) =====
# If not provided -> DEV mode (logs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tokana-app
SMTP_PASS=ueuu uzlc tfch wsdo
SMTP_FROM="Tokana <no-reply@tokana.mg>"

# ===== Rate limit (optional) =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===== Business contact (manual handling) =====
# Phone number shown to users when weight > 5kg requires manual handling (Optional)
CONTACT_PHONE=+26134XXXXXXX
