# Public variables available in the Expo app (do NOT put secrets here)
# These will be embedded in the client bundle. Anything here is PUBLIC.

# Base URL of the Tokana API (e.g. your server)
# Examples:
# - Local dev (web): http://localhost:5000
# - Local dev (device on same LAN): http://<your-computer-LAN-IP>:5000
# - Production: https://api.tokana.mg
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Mapbox public token (for geocoding/maps). Public token is OK to embed in client.
# Create one in your Mapbox account and paste it here.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN
