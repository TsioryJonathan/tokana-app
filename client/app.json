{
  "expo": {
    "name": "Tokana",
    "slug": "tokana-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "tokana",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaPLEASE_REPLACE_WITH_VALID_API_KEY"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "usesCleartextTraffic": true,
      "package": "com.tokana.tokana",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "jsEngine": "hermes"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#ffffff",
      "translucent": true,
      "hidden": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "assetBundlePatterns": [
      "assets/fonts/*"
    ],
    "extra": {
      "API_BASE_DEV": "https://tokana-app.onrender.com",
      "API_BASE_PROD": "https://tokana-app.onrender.com",
      "router": {},
      "eas": {
        "projectId": "cb6e54a5-9dc1-47df-8fca-79e873803134"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
